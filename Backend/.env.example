# ---- Copy this file to Backend/.env and fill in values. .env is gitignored. ----

# --- Postgres (local docker; you can leave these defaults) ---
POSTGRES_USER=keldran
POSTGRES_PASSWORD=change-me-local-dev
POSTGRES_DB=keldran
POSTGRES_PORT=5432

# --- Redis (local docker) ---
REDIS_PORT=6379

# --- Gateway ---
GATEWAY_PORT=8080
# Secret used to sign session JWTs. Use a long random string.
JWT_SECRET=change-me-to-a-long-random-string
# Session token time-to-live (seconds)
SESSION_TTL=3600
# Address the game server should connect clients to (host:port of the dedicated server).
DEFAULT_SHARD_ADDRESS=127.0.0.1:7777

# --- NPC Dialogue Service ---
DIALOGUE_PORT=8090
# OpenRouter key — runtime "living NPC" dialogue. Service still works without it
# (falls back to authored lines). Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Default free/cheap model for ambient NPCs
OPENROUTER_MODEL=google/gemma-4-31b-it:free
# Per-account dialogue rate limit (requests per minute)
DIALOGUE_RATE_LIMIT_PER_MIN=20

# --- Content generation (Tools/gen) — needed at M3, not for the backend ---
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
# Hard spend cap for a single `make generate` run (USD)
GEN_SPEND_CAP_USD=10
